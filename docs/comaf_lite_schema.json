{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comaf.io/schema/comaf-lite-1.337.0.json",
  "title": "COMAF-Lite Model",
  "description": "Schema for COMAF-Lite v1.337.0 physical models. Aligned with QULT-C paper Appendix D (v1.337lulz). v0.2: added PHYSICS_QUANTITY block type (FORCE/POWER/PRESSURE/CURVATURE/CHARGE/ENTROPY_UNIT/UNCERTAINTY). See TRACEABILITY.md.",
  "type": "object",
  "required": ["entity", "cycle", "frame", "units", "blocks"],
  "properties": {
    "model": {
      "type": "string",
      "description": "Optional model identifier"
    },
    "entity": {
      "type": "string",
      "description": "The physical entity being modeled"
    },
    "cycle": {
      "type": "string",
      "pattern": "^CPL-[0-9]+$|^CPL-infinity$",
      "description": "Conformal Planck Loop identifier"
    },
    "frame": {
      "type": "object",
      "required": ["variable", "start", "end"],
      "properties": {
        "variable": {"type": "string"},
        "start":    {"type": "number"},
        "end":      {"type": "number"},
        "units":    {"$ref": "#/$defs/unit_suffix"}
      }
    },
    "units": {
      "type": "string",
      "enum": ["Planck", "SI", "PNMS"]
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/block"}
    }
  },
  "$defs": {
    "unit_suffix": {
      "type": "string",
      "enum": [
        "Plaseconds", "Plameters",  "WarpTick",
        "Plasecond",  "Plameter",   "PlaNewtons",
        "lambda_p",   "t_p",        "m_p",
        "E_p",        "k_B",        "dimensionless",
        "Ricci-Bits", "PlaWatts",   "PlaPascals",
        "PlaCoulombs","s",          "m",            "J", "kg"
      ]
    },

    "block": {
      "oneOf": [
        {"$ref": "#/$defs/state_block"},
        {"$ref": "#/$defs/entropy_block"},
        {"$ref": "#/$defs/geometry_block"},
        {"$ref": "#/$defs/stability_block"},
        {"$ref": "#/$defs/collapse_block"},
        {"$ref": "#/$defs/warp_block"},
        {"$ref": "#/$defs/emit_block"},
        {"$ref": "#/$defs/transition_block"},
        {"$ref": "#/$defs/event_block"},
        {"$ref": "#/$defs/comment_block"},
        {"$ref": "#/$defs/physics_quantity_block"},
        {"$ref": "#/$defs/assignment_block"}
      ]
    },

    "state_block": {
      "type": "object",
      "required": ["type", "name", "body"],
      "properties": {
        "type": {"const": "STATE"},
        "name": {"type": "string"},
        "body": {
          "type": "object",
          "required": ["init", "hamiltonian"],
          "properties": {
            "init": {
              "oneOf": [
                {"type": "number"},
                {"type": "string", "pattern": "^\\|.+>$"},
                {
                  "type": "object",
                  "required": ["superposition"],
                  "properties": {
                    "superposition": {
                      "type": "array",
                      "items": {"type": "string", "pattern": "^\\|.+>$"}
                    }
                  }
                }
              ]
            },
            "hamiltonian": {
              "type": "string",
              "$comment": "String value is interpreted by the transpiler as the QULT-C Hamiltonian (Eq. 4.1). Accepted values: H_QULT(R, S) or a custom MATH_EXPR."
            }
          }
        }
      }
    },

    "entropy_block": {
      "type": "object",
      "required": ["type", "name", "body"],
      "properties": {
        "type": {"const": "ENTROPY"},
        "name": {"type": "string"},
        "body": {
          "type": "object",
          "required": ["init", "max", "scale"],
          "properties": {
            "init":        {"type": "number"},
            "max":         {"type": "number"},
            "scale":       {"type": "number"},
            "scale_units": {"$ref": "#/$defs/unit_suffix"}
          }
        }
      }
    },

    "geometry_block": {
      "type": "object",
      "required": ["type", "field_equation"],
      "properties": {
        "type":           {"const": "GEOMETRY"},
        "field_equation": {"type": "string"}
      }
    },

    "stability_block": {
      "type": "object",
      "required": ["type", "metric_name", "metric_var", "expression"],
      "properties": {
        "type":        {"const": "STABILITY"},
        "metric_name": {"type": "string"},
        "metric_var":  {"type": "string"},
        "expression":  {"type": "string"}
      }
    },

    "collapse_block": {
      "type": "object",
      "required": ["type", "condition"],
      "properties": {
        "type":        {"const": "IF_COLLAPSE"},
        "condition":   {"type": "string"},
        "energy":      {"type": "string"},
        "resolution":  {"type": "string"},
        "decoherence": {"type": "string"}
      }
    },

    "warp_block": {
      "type": "object",
      "required": ["type", "condition"],
      "properties": {
        "type":      {"const": "IF_WARP"},
        "condition": {"type": "string"},
        "velocity":  {"type": "string"},
        "safety":    {"type": "string"},
        "target":    {"type": "string"}
      }
    },

    "emit_block": {
      "type": "object",
      "required": ["type", "condition"],
      "properties": {
        "type":      {"const": "IF_EMIT"},
        "condition": {"type": "string"},
        "energy":    {"type": "string"},
        "decay":     {"type": "string"},
        "event":     {"type": "string"}
      }
    },

    "transition_block": {
      "type": "object",
      "required": ["type", "event", "statements"],
      "properties": {
        "type":  {"const": "ON_TRANSITION"},
        "event": {"type": "string"},
        "statements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["variable", "expression"],
            "properties": {
              "variable":   {"type": "string"},
              "expression": {"type": "string"}
            }
          }
        }
      }
    },

    "event_block": {
      "type": "object",
      "required": ["type", "name", "statements"],
      "properties": {
        "type": {"const": "EVENT"},
        "name": {"type": "string"},
        "statements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["variable", "expression"],
            "properties": {
              "variable":   {"type": "string"},
              "expression": {"type": "string"}
            }
          }
        }
      }
    },

    "comment_block": {
      "type": "object",
      "required": ["type", "text"],
      "description": "COMMENT blocks (# ...) are stripped by the COMAF-Lite parser before AST construction. Represented here for round-trip serialization fidelity; no semantic content.",
      "properties": {
        "type": {"const": "COMMENT"},
        "text": {"type": "string"}
      }
    },

    "physics_quantity_block": {
      "type": "object",
      "required": ["type", "keyword", "name", "expression"],
      "description": "COMAF × PNMS addendum block (v1.3.22). Covers FORCE, POWER, PRESSURE, CURVATURE, CHARGE, ENTROPY_UNIT, UNCERTAINTY. Ref: TRACEABILITY.md §3.",
      "properties": {
        "type":       {"const": "PHYSICS_QUANTITY"},
        "keyword":    {
          "type": "string",
          "enum": ["FORCE", "POWER", "PRESSURE", "CURVATURE", "CHARGE", "ENTROPY_UNIT", "UNCERTAINTY"]
        },
        "name":       {"type": "string"},
        "expression": {"type": "string"},
        "unit":       {"type": "string"}
      }
    },

    "assignment_block": {
      "type": "object",
      "required": ["type", "target", "operator", "expression"],
      "description": "Top-level assignment (parse artifact from field_equation lines in GEOMETRY blocks).",
      "properties": {
        "type":       {"const": "ASSIGNMENT"},
        "target":     {"type": "string"},
        "operator":   {"type": "string"},
        "expression": {"type": "string"}
      }
    }
  }
}
